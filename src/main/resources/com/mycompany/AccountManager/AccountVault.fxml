<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.AccountManager.AccountVaultController">

    <stylesheets>
        <URL value="@/styles/AccountVaultStyling.css" />
    </stylesheets>
    <center>
        <TableView fx:id="accountTable">
            <columns>
                <TableColumn fx:id="categoryCol" text="Account Category" />
                <TableColumn fx:id="websiteNameCol" prefWidth="75.0" text="Website/App Name" />
                <TableColumn fx:id="usernameCol" text="Account UserName" />
                <TableColumn fx:id="passwordCol" text="Password" />
                <TableColumn fx:id="descriptionCol" text="Description" />
            </columns>
        </TableView>


    </center>

    <bottom>
        <HBox prefHeight="60">

            <padding>
                <Insets bottom="10" left="20" right="20" top="10" />
            </padding>

            <children>
                <Button onAction="#back_Btn_call" styleClass="logout-button" text="Back" textFill="WHITE">

                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Button>
                <Region HBox.hgrow="ALWAYS" />

                <Button onAction="#AddPass_Btn" text="Add Account" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Button>
                <Region HBox.hgrow="ALWAYS" />

                <Button onAction="#EditPass_Btn" text="Edit/View Acc Details" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Button>

                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#RecoveryPhrase_Btn_call" text="Account Recovery Phrases" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Button>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#deleteAccount_Btn_call" text="Delete Account" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Button>

            </children>


        </HBox>

    </bottom>
    <top>
        <VBox alignment="TOP_CENTER" spacing="20">

            <padding>
                <Insets bottom="15" top="15" />
            </padding>

            <children>

                <Label text="Account Vault" textFill="WHITE">
                    <font>
                        <Font name="Century Gothic Bold Italic" size="18.0" />
                    </font>
                </Label>

                <HBox alignment="CENTER" spacing="40.0">

                    <children>

                        <Label text="Select Account Category" textFill="WHITE">
                            <font>
                                <Font name="Arial Black" size="14.0" />
                            </font>
                        </Label>

                        <ComboBox fx:id="selectAccountCategory_ComboBox" prefWidth="180" />
                        <Button mnemonicParsing="false" onAction="#reset_Btn_call" text="Reset Category" />

                    </children>

                </HBox>


            </children>

        </VBox>
    </top>


</BorderPane>
