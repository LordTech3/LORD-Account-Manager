<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" stylesheets="@/styles/userdashboard.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.AccountManager.UserDashboardController">

    <top>
        <Label id="titleLabel" text="User Dashboard" BorderPane.alignment="CENTER">
            <font>
                <Font name="Century Gothic Bold Italic" size="24.0" />
            </font>
        </Label>
    </top>

    <center>
        <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="TOP_CENTER">

            <children>

                <Button mnemonicParsing="false" onAction="#PasswordVault_Btn_call" text="Account Vault">
                    <font>
                        <Font name="Arial Bold" size="18.0" />
                    </font>
                </Button>

                <Region VBox.vgrow="ALWAYS" />

                <Button mnemonicParsing="false" onAction="#AccountCategories_Btn_call" text="Account Categories">
                    <font>
                        <Font name="Arial Bold" size="18.0" />
                    </font>
                </Button>

                <Region VBox.vgrow="ALWAYS" />

                <Button mnemonicParsing="false" onAction="#ChangeUserDetails_Btn_call" text="Change User Details">
                    <font>
                        <Font name="Arial Bold" size="18.0" />
                    </font>
                </Button>

                <Region VBox.vgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#deleteUser_Btn_call" text="Delete User">
                    <font>
                        <Font name="Arial Bold" size="18.0" />
                    </font>
                </Button>
                <Region VBox.vgrow="ALWAYS" />

                <Button mnemonicParsing="false" onAction="#Logout_Btn_call" text="Log Out">
                    <font>
                        <Font name="Arial Bold" size="18.0" />
                    </font>
                </Button>

            </children>

            <padding>
                <Insets bottom="50.0" top="50.0" />
            </padding>

        </VBox>
    </center>

</BorderPane>
